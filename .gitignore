*.py[cod]
.venv/
venv/

# Large model weights & artifacts — NEVER commit (any location)
*.pt
*.pth
*.onnx
*.ckpt
*.safetensors
*.bin
*.gguf
*.h5
*.tflite
*.pkl
training/checkpoints/**
!training/checkpoints/.gitkeep
!checkpoints/.gitkeep

